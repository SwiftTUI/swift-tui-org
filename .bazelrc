common --enable_bzlmod
common --announce_rc

test --test_output=errors
test --test_env=PATH
test --test_env=HOME
test --test_env=TMPDIR
test --test_env=DEVELOPER_DIR
# child_ci_status authenticates its GitHub API queries when a token is present
# and hard-fails (instead of skip-on-offline) when CI is set.
test --test_env=GITHUB_TOKEN
test --test_env=GH_TOKEN
test --test_env=CI
test --test_timeout=3600
