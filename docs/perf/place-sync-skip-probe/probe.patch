diff --git a/Sources/SwiftTUICore/Support/PlacePerfProbe.swift b/Sources/SwiftTUICore/Support/PlacePerfProbe.swift
new file mode 100644
index 00000000..6b726d74
--- /dev/null
+++ b/Sources/SwiftTUICore/Support/PlacePerfProbe.swift
@@ -0,0 +1,32 @@
+#if canImport(Darwin)
+  internal import Darwin
+#elseif canImport(Glibc)
+  internal import Glibc
+#elseif canImport(Musl)
+  internal import Musl
+#elseif canImport(WASILibc)
+  internal import WASILibc
+#endif
+
+/// TEMPORARY measurement instrumentation for the `place_ms` retained-reuse
+/// residual. NOT a feature — archived as a patch, not landed on `main`.
+///
+/// `TERMUI_PERF_PLACE_DISABLE_SYNC_SKIP` (read once, cached): force the prior
+/// behavior where a fully-identical reused subtree is still re-synced
+/// (`synchronizeRetainedPhaseMetadata`) instead of returned untouched. Sound (it
+/// is the old behavior); used to A/B the identical-subtree sync skip against the
+/// baseline in a single sweep with no machine drift.
+package enum PlacePerfProbe {
+  package static let disableSyncSkip: Bool =
+    environmentFlag(named: "TERMUI_PERF_PLACE_DISABLE_SYNC_SKIP")
+
+  private static func environmentFlag(named name: String) -> Bool {
+    unsafe name.withCString { cName in
+      guard let rawValue = unsafe getenv(cName) else {
+        return false
+      }
+      let value = unsafe String(cString: rawValue)
+      return value != "" && value != "0"
+    }
+  }
+}
