diff --git a/Sources/SwiftTUIRuntime/Rendering/FrameHeadDraftTransaction.swift b/Sources/SwiftTUIRuntime/Rendering/FrameHeadDraftTransaction.swift
index e3cd98cf..59153ba3 100644
--- a/Sources/SwiftTUIRuntime/Rendering/FrameHeadDraftTransaction.swift
+++ b/Sources/SwiftTUIRuntime/Rendering/FrameHeadDraftTransaction.swift
@@ -80,10 +80,45 @@ package final class FrameHeadTransaction {
   ///   elision path; keep both in sync until they intentionally diverge.
   package func commit() -> RuntimeRegistrationDiagnostics {
     precondition(!didCommit && !didDiscard)
+    // TEMPORARY: the four sub-commits are lap-timed so the dominant O(tree)
+    // `commit_ms` cost (this method) can be attributed to a specific sub-step.
+    // Single code path; the clock reads are negligible and the accumulation is
+    // gated by ``CommitBreakdownProbe/isEnabled``. Revert with the rest of the
+    // commit-ms instrumentation. Keep in sync with ``commitElided()``.
+    if CommitBreakdownProbe.isEnabled {
+      switch graphDraft.runtimeRegistrationPublication {
+      case .all:
+        CommitBreakdownProbe.recordPublication(all: true, subtrees: false, rootCount: 0)
+      case .subtrees(let roots):
+        CommitBreakdownProbe.recordPublication(
+          all: false, subtrees: true, rootCount: roots.count)
+      case .unchanged:
+        CommitBreakdownProbe.recordPublication(all: false, subtrees: false, rootCount: 0)
+      }
+    }
+    let clock = ContinuousClock()
+    var mark = clock.now
+    func lap() -> Duration {
+      let now = clock.now
+      defer { mark = now }
+      return mark.duration(to: now)
+    }
     let diagnostics = graphDraft.commitRuntimeRegistrations(from: viewGraph)
+    let graphRegistrations = lap()
     observationDraft?.commit()
+    let observation = lap()
     presentationPortalDraft.commit()
+    let portal = lap()
     animationDraft.commit()
+    let animation = lap()
+    if CommitBreakdownProbe.isEnabled {
+      CommitBreakdownProbe.recordTxn(
+        graphRegistrations: graphRegistrations,
+        observation: observation,
+        portal: portal,
+        animation: animation
+      )
+    }
     didCommit = true
     return diagnostics
   }
